# StatsBomb open data path (optional if using package defaults)
STATSBOMB_DATA_DIR=./data/statsbomb

# football-data.org API key
FOOTBALL_DATA_ORG_API_KEY=your_football_data_org_api_key_here

# API-Football via RapidAPI credentials
API_FOOTBALL_API_KEY=your_api_football_api_key_here
API_FOOTBALL_API_HOST=v3.football.api-sports.io

# Open Football Data GitHub base path (optional)
OPEN_FOOTBALL_DATA_BASE_URL=https://raw.githubusercontent.com/openfootball/football.json/master

# Optional Hugging Face API key for cloud-hosted LLM report generation
HUGGINGFACE_API_KEY=your_huggingface_api_key_here